rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.email == "ramongalera22@gmail.com" ||
        request.auth.token.email == "carlosgalera2roman@gmail.com" ||
        request.auth.token.email == "esther.montoro@gmail.com"
      );
    }

    function isAuth() {
      return request.auth != null;
    }

    // === MODERADORES ===
    match /moderadores/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === PROPUESTAS DE CONTENIDO ===
    match /propuestas_contenido/{docId} {
      allow create: if isAuth()
                    && request.resource.data.email == request.auth.token.email;
      allow read: if isAuth();
      allow update: if isAuth();
      allow delete: if isSuperAdmin();
    }

    // === CONFIG (API keys, etc.) — solo superadmin ===
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === ACCESOS ===
    match /accesos/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isSuperAdmin();
    }

    match /accesos_profesionales/{docId} {
      allow create: if isAuth();
      allow read, update, delete: if isSuperAdmin();
    }

    // === PROTOCOLOS ===
    match /protocolos/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === GUARDIA_CAMBIOS ===
    match /guardia_cambios/{docId} {
      allow read, write: if isAuth();
    }

    // ═══════════════════════════════════════════════════════
    // === CUADERNOS PRIVADOS POR USUARIO =====================
    // Cada usuario solo puede leer y escribir sus propios docs.
    // Ni superadmins pueden leer los cuadernos de otro usuario.
    // ═══════════════════════════════════════════════════════
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Bloquear todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
